{
  "name": "code-challenge-fe",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "tw": "npx @tailwindcss/cli -i src/tailwind.css -o src/tailwind-output.css",
    "tw:watch": "npx @tailwindcss/cli -i src/tailwind.css -o src/tailwind-output.css --watch",
    "start": "concurrently \"npm run tw:watch\" \"ng serve\"",
    "build": "npm run tw && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "npm run tw && playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/entity": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "description": "This project was generated using [Angular CLI](https://github.com/angular/angular-cli) version 21.2.6.",
  "main": "postcss.config.js",
  "keywords": [],
